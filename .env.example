# Azure Speech Service credentials
# Get these from: https://portal.azure.com -> Your Speech Service -> Keys and Endpoint
# If AZURE_SPEECH_KEY is unset, falls back to Azure AD auth (az login / DefaultAzureCredential).
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Full ARM resource ID — required when using Azure AD auth (no API key).
# Find it via: az cognitiveservices account show --name <name> --resource-group <rg> --query id -o tsv
# AZURE_SPEECH_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# Optional: Default input device name or index
# Run `python transcribe.py --list-devices` to see available devices
# RTT_INPUT_DEVICE="BlackHole 16ch"

# Mix the microphone into the captured audio so your voice appears in the transcript.
# Set to 1 to enable; install.sh on macOS sets this automatically.
# RTT_INCLUDE_MIC=1
# RTT_MIC_DEVICE="MacBook Pro Microphone"   # default: system default input
# RTT_MIC_GAIN=1.0                          # 0.0–2.0 sensible range

# Windows-only: capture the OUTPUT of RTT_INPUT_DEVICE via WASAPI loopback (no virtual cable required).
# RTT_USE_LOOPBACK=1
# RTT_INPUT_DEVICE=6
